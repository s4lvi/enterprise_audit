# Copy this to .env.local for local dev. Do NOT commit .env.local.
#
# The values below come from your local Supabase stack (`supabase status`)
# or, for hosted dev against the cloud project, from the Supabase dashboard
# (Project Settings -> API).
#
# In production these are set in Vercel project env vars, not here.

# Public — safe to expose to the browser. Rate-limited; respects RLS.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local anon key from `supabase status`>

# Server-only secret — bypasses RLS. NEVER expose to the client. Used in
# server actions / route handlers / migrations only.
SUPABASE_SERVICE_ROLE_KEY=<local service_role key from `supabase status`>
